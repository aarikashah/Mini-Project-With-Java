import java.io.*;
import java.util.*;

class BankSystem{

static Map<Integer,String> names=new HashMap<>();
static Map<Integer,Double> balance=new HashMap<>();

static final String FILE="bank.txt";

static boolean validAmount(double amt){
return Math.round(amt*100)==amt*100;
}

static void load() throws Exception{

BufferedReader br=new BufferedReader(new FileReader(FILE));

String line;

while((line=br.readLine())!=null){

String data[]=line.split(",");

int id=Integer.parseInt(data[0]);

names.put(id,data[1]);

balance.put(id,Double.parseDouble(data[2]));

}

br.close();

}

static void save() throws Exception{

BufferedWriter bw=new BufferedWriter(new FileWriter(FILE));

for(int id:names.keySet()){

bw.write(id+","+names.get(id)+","+balance.get(id));

bw.newLine();

}

bw.close();

}

public static void main(String args[]){

Scanner sc=new Scanner(System.in);

int choice;

try{

load();

}catch(Exception e){

System.out.println("Starting new file");

}

do{

System.out.println("\n1.Create");
System.out.println("2.Deposit");
System.out.println("3.Withdraw");
System.out.println("4.Display");
System.out.println("5.Exit");

choice=sc.nextInt();

try{

switch(choice){

case 1:

System.out.println("Enter CID");

int cid=sc.nextInt();

if(names.containsKey(cid))
throw new Exception("Account exists");

System.out.println("Enter Name");

String name=sc.next();

System.out.println("Enter amount");

double amt=sc.nextDouble();

if(!validAmount(amt))
throw new Exception("Only 2 decimals");

if(amt<1000)
throw new Exception("Minimum 1000");

names.put(cid,name);

balance.put(cid,amt);

System.out.println("Account created");

break;

case 2:

System.out.println("Enter CID");

int did=sc.nextInt();

if(!names.containsKey(did))
throw new Exception("Account not found");

System.out.println("Enter deposit");

double damt=sc.nextDouble();

if(!validAmount(damt))
throw new Exception("Only 2 decimals");

if(damt<1)
throw new Exception("Minimum deposit 1");

balance.put(did,balance.get(did)+damt);

System.out.println("Deposit done");

break;

case 3:

System.out.println("Enter CID");

int wid=sc.nextInt();

if(!names.containsKey(wid))
throw new Exception("Account not found");

System.out.println("Enter withdraw");

double wamt=sc.nextDouble();

if(!validAmount(wamt))
throw new Exception("Only 2 decimals");

if(wamt<=1)
throw new Exception("Withdraw >1");

if(balance.get(wid)-wamt<1000)
throw new Exception("Minimum balance 1000 required");

balance.put(wid,balance.get(wid)-wamt);

System.out.println("Withdraw done");

break;

case 4:

for(int id:names.keySet()){

System.out.println(id+" "+names.get(id)+" "+
String.format("%.2f",balance.get(id)));

}

break;

case 5:

save();

System.out.println("Saved");

break;

default:

System.out.println("Invalid");

}

}catch(Exception e){

System.out.println("Error: "+e.getMessage());

}

}while(choice!=5);

}
}
