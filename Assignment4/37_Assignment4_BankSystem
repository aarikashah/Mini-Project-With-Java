import java.io.*;
import java.util.*;

class BankSystem{

    public static void main(String args[]){

        Scanner sc=new Scanner(System.in);

        int cid;
        String cname;
        double amount;
        int choice;

        do{

            System.out.println("\n1.Create Account");
            System.out.println("2.Withdraw");
            System.out.println("3.Deposit");
            System.out.println("4.Display Records");
            System.out.println("5.Exit");

            System.out.println("Enter choice:");
            choice=sc.nextInt();

            try{

                switch(choice){

                    case 1:

                        System.out.println("Enter CID:");
                        cid=sc.nextInt();

                        if(cid<1 || cid>20)
                            throw new Exception("CID must be between 1 and 20");

                        System.out.println("Enter Name:");
                        cname=sc.next();

                        System.out.println("Enter Amount:");
                        amount=sc.nextDouble();

                        if(amount<=0)
                            throw new Exception("Amount must be positive");

                        if(amount<1000)
                            throw new Exception("Minimum amount is 1000");

                        FileWriter fw=new FileWriter("bank.txt",true);

                        fw.write(cid+" "+cname+" "+String.format("%.2f",amount)+"\n");

                        fw.close();

                        System.out.println("Account created");

                        break;

                    case 2:

                        System.out.println("Enter Balance:");
                        double bal=sc.nextDouble();

                        System.out.println("Enter withdraw amount:");
                        double wamt=sc.nextDouble();

                        if(wamt<=1)
                            throw new Exception("Withdraw amount must be greater than 1");

                        if(wamt>bal)
                            throw new Exception("Insufficient balance");

                        String wstr = String.valueOf(wamt);

                        if(wstr.contains(".")){
                            if(wstr.substring(wstr.indexOf('.')+1).length()>2)
                                throw new Exception("Only 2 decimal places allowed");
                        }

                        bal=bal-wamt;

                        System.out.println("Remaining balance: "+String.format("%.2f",bal));

                        break;

                    case 3:

                        System.out.println("Enter Balance:");
                        double dbal=sc.nextDouble();

                        System.out.println("Enter deposit amount:");
                        double damt=sc.nextDouble();

                        if(damt<=0)
                            throw new Exception("Deposit must be positive");

                        String dstr = String.valueOf(damt);

                        if(dstr.contains(".")){
                            if(dstr.substring(dstr.indexOf('.')+1).length()>2)
                                throw new Exception("Only 2 decimal places allowed");
                        }

                        dbal=dbal+damt;

                        System.out.println("Updated balance: "+String.format("%.2f",dbal));

                        break;

                    case 4:

                        BufferedReader br=new BufferedReader(new FileReader("bank.txt"));

                        String line;

                        System.out.println("\nCustomer Records:");

                        while((line=br.readLine())!=null){
                            System.out.println(line);
                        }

                        br.close();

                        break;

                    case 5:

                        System.out.println("Program ended");

                        break;

                    default:

                        System.out.println("Invalid choice");

                }

            }

            catch(Exception e){

                System.out.println("Error: "+e.getMessage());

            }

        }while(choice!=5);

        sc.close();

    }
}
